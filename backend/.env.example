DATABASE_URL=postgres://postgres:postgres@localhost:5432/plans

# JWT_SECRET: dev default is fine locally, but in production the server
# refuses to start unless this is set to a strong (>= 32 char) secret that
# is not one of the known dev placeholders.
JWT_SECRET=dev-secret-change-in-prod

# OTP: mock MVP — any phone accepts this code during /auth/otp/verify.
OTP_CODE=1111
PORT=3001

# NODE_ENV: set to "production" in deployment to enable strict JWT_SECRET
# checks, CORS whitelist enforcement, etc.
NODE_ENV=development

# CORS_ORIGIN: comma-separated list of allowed origins (e.g. "https://app.example.com,https://admin.example.com").
# When unset + NODE_ENV=production: CORS is effectively disabled (no origins allowed).
# When unset + NODE_ENV!=production: the request origin is reflected.
# CORS_ORIGIN=https://plans.app
